# =============================================================================
# Pressmuenzen-Bot configuration template.
#
# Copy this file to `.env` and fill in the real values. `.env` is git-ignored
# and is the ONLY place secrets live. Compose loads it via `env_file:`.
#
#   cp .env.example .env && $EDITOR .env
#
# There is no `private/` directory and no committed token anymore.
# =============================================================================

# --- Telegram -----------------------------------------------------------------
# Bot token from @BotFather (looks like "123456789:AA...").
TELEGRAM_TOKEN=

# Comma-separated Telegram chat IDs that are treated as admins (moderation).
# This is the SINGLE source of truth for admin rights -- not stored in the DB.
# To find your own chat id, message the bot and send /whoami, or message
# @userinfobot. Add an admin = edit this value and restart; no migration.
ADMIN_CHAT_IDS=

# --- Database -----------------------------------------------------------------
# These three are consumed by the `db` (postgis) container.
POSTGRES_USER=pressmuenzen
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=pressmuenzen

# Async SQLAlchemy URL used by the app. Host `db` is the compose service name.
# Must match the three POSTGRES_* values above.
DATABASE_URL=postgresql+asyncpg://pressmuenzen:change-me-to-a-long-random-string@db:5432/pressmuenzen

# --- Web / public surface -----------------------------------------------------
# Public base URL used to build hosted-map links sent by the bot. No trailing slash.
PUBLIC_BASE_URL=https://map.example.de

# Domains Caddy serves (TLS issued automatically for these).
PUBLIC_DOMAIN=map.example.de
ADMIN_DOMAIN=admin.example.de

# bcrypt hash for the admin panel HTTP basic auth (defense in depth).
# Generate with: docker compose run --rm caddy caddy hash-password --plaintext 'yourpassword'
ADMIN_PASSWORD_HASH=

# Secret used to sign short-lived hosted-map tokens (GET /map/{token}).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MAP_TOKEN_SECRET=

# --- Geocoding (Nominatim) ----------------------------------------------------
# Nominatim ToS REQUIRES a real, identifying User-Agent with contact info.
NOMINATIM_USER_AGENT=pressmuenzen-bot (malte.westerhagen@zollsoft.de)

# --- Scraper ------------------------------------------------------------------
SCRAPER_BASE_URL=http://www.elongated-coin.de/phpBB3/
SCRAPER_MAIN_FORUM_URL=http://www.elongated-coin.de/phpBB3/viewforum.php?f=126
# Parse-rate canary threshold: abort a run if the clean-parse share drops below this.
SCRAPER_CANARY_MIN_PARSE_RATE=0.85

# --- Container image (set by deploy.sh in production; ignore locally) ---------
IMAGE_REPO=ghcr.io/maltebo/geo
IMAGE_TAG=local

# --- Logging ------------------------------------------------------------------
# json (production, journald) or console (local dev).
LOG_FORMAT=json
LOG_LEVEL=INFO
